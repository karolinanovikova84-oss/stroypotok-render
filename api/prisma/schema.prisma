generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  COORDINATOR
  WORKER
  CLIENT
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ShiftStatus {
  PLANNED
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ShiftAssignmentStatus {
  APPLIED
  CONFIRMED
  REJECTED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum RequestStatus {
  NEW
  IN_REVIEW
  ESTIMATING
  APPROVED
  REJECTED
  CONVERTED
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ResourceStatus {
  NEEDED
  ORDERED
  RESERVED
  DELIVERED
  CANCELLED
}

enum ProjectWorkflowStatus {
  OBJECT_CREATED
  PLANNING
  PLAN_SUBMITTED
  APPROVED_TO_START
  IN_PROGRESS
  COMPLETED
}

enum ShiftKind {
  REGULAR
  PREMIUM
  REPLACEMENT
}

enum WorkSchedule {
  FIVE_TWO
  TWO_TWO
}

enum AbsenceType {
  SICK_LEAVE
  VACATION
}

enum AbsenceStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  ACCRUED
  APPROVED
  PAID
}

model User {
  id                String            @id @default(cuid())
  phone             String            @unique
  email             String?           @unique
  passwordHash      String
  firstName         String
  lastName          String?
  role              UserRole
  specialization    String?
  qualification     String?
  experienceYears   Int?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  managedProjects   Project[]         @relation("ProjectManager")
  clientProjects    Project[]         @relation("ProjectClient")
  clientRequests    ClientRequest[]   @relation("ClientRequests")
  createdShifts     Shift[]           @relation("ShiftCreator")
  assignments       ShiftAssignment[]
  absenceRequests   AbsenceRequest[]  @relation("WorkerAbsenceRequests")
  reviewedAbsences  AbsenceRequest[]  @relation("ManagerAbsenceReviews")
  createdPayrollDeductions PayrollDeduction[] @relation("PayrollDeductionCreator")
}

model ClientRequest {
  id                String          @id @default(cuid())
  title             String
  description       String
  address           String
  clientName        String
  clientPhone       String
  clientEmail       String?
  desiredStartDate  DateTime?
  desiredEndDate    DateTime?
  budget            Decimal?        @db.Decimal(12, 2)
  priority          RequestPriority @default(NORMAL)
  status            RequestStatus   @default(NEW)
  notes             String?
  clientId          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  client            User?           @relation("ClientRequests", fields: [clientId], references: [id], onDelete: SetNull)
  project           Project?
}

model Project {
  id                String      @id @default(cuid())
  title             String
  description       String?
  address           String
  status            ProjectStatus @default(DRAFT)
  clientName        String?
  clientPhone       String?
  startDate         DateTime?
  endDate           DateTime?
  managerId         String?
  clientId          String?
  requestId         String?     @unique
  workStage         String?
  plannedWorkers    Int?
  estimatedBudget   Decimal?    @db.Decimal(12, 2)
  workflowStatus    ProjectWorkflowStatus @default(OBJECT_CREATED)
  plannedStartDate  DateTime?
  plannedEndDate    DateTime?
  teamRequestedAt   DateTime?
  teamReadyAt       DateTime?
  resourcesRequestedAt DateTime?
  resourcesReadyAt  DateTime?
  planSubmittedAt   DateTime?
  startApprovedAt   DateTime?
  clientNotifiedAt  DateTime?
  managerPlanNote   String?
  coordinatorNote   String?
  clientNotice      String?
  workSchedule      WorkSchedule @default(FIVE_TWO)
  completedAt       DateTime?
  completionNote    String?
  payrollClosedAt   DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  manager           User?       @relation("ProjectManager", fields: [managerId], references: [id])
  client            User?       @relation("ProjectClient", fields: [clientId], references: [id], onDelete: SetNull)
  request           ClientRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  shifts            Shift[]
  resources         ResourceNeed[]
  absenceRequests   AbsenceRequest[]
}

model Shift {
  id                String                @id @default(cuid())
  projectId         String
  createdById       String?
  title             String
  description       String?
  startsAt          DateTime
  endsAt            DateTime
  workersNeeded     Int
  hourlyRate        Decimal               @db.Decimal(10, 2)
  payMultiplier     Decimal               @default(1.00) @db.Decimal(4, 2)
  shiftHours        Decimal               @default(8.00) @db.Decimal(5, 2)
  estimatedShiftCount Int?
  kind              ShiftKind             @default(REGULAR)
  workSchedule      WorkSchedule          @default(FIVE_TWO)
  isWeekend         Boolean               @default(false)
  isHoliday         Boolean               @default(false)
  status            ShiftStatus           @default(PLANNED)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  project           Project               @relation(fields: [projectId], references: [id])
  createdBy         User?                 @relation("ShiftCreator", fields: [createdById], references: [id])
  assignments       ShiftAssignment[]
  replacementForAbsence AbsenceRequest?   @relation("AbsenceReplacementShift")
}

model ShiftAssignment {
  id                String                  @id @default(cuid())
  shiftId           String
  workerId          String
  status            ShiftAssignmentStatus   @default(APPLIED)
  appliedAt         DateTime                @default(now())
  confirmedAt       DateTime?
  notes             String?
  scheduledShifts   Int?
  workedShifts      Int                   @default(0)
  accruedAmount     Decimal               @default(0.00) @db.Decimal(12, 2)
  paidAmount        Decimal               @default(0.00) @db.Decimal(12, 2)
  payrollStatus     PayrollStatus         @default(ACCRUED)
  payrollUpdatedAt  DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  shift             Shift                   @relation(fields: [shiftId], references: [id])
  worker            User                    @relation(fields: [workerId], references: [id])
  absenceRequests   AbsenceRequest[]
  payrollDeductions PayrollDeduction[]

  @@unique([shiftId, workerId])
}

model PayrollDeduction {
  id                String          @id @default(cuid())
  assignmentId      String
  createdById       String?
  startsAt          DateTime
  endsAt            DateTime
  shiftsCount       Int
  amount            Decimal         @db.Decimal(12, 2)
  reason            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  assignment        ShiftAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  createdBy         User?           @relation("PayrollDeductionCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([assignmentId])
  @@index([createdById])
}

model AbsenceRequest {
  id                String          @id @default(cuid())
  workerId          String
  projectId         String
  assignmentId      String?
  reviewedById      String?
  replacementShiftId String?        @unique
  type              AbsenceType
  status            AbsenceStatus   @default(REQUESTED)
  startsAt          DateTime
  endsAt            DateTime
  reason            String?
  managerNote       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  reviewedAt        DateTime?
  worker            User            @relation("WorkerAbsenceRequests", fields: [workerId], references: [id])
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignment        ShiftAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  reviewedBy        User?           @relation("ManagerAbsenceReviews", fields: [reviewedById], references: [id])
  replacementShift  Shift?          @relation("AbsenceReplacementShift", fields: [replacementShiftId], references: [id], onDelete: SetNull)
}

model ResourceNeed {
  id                String          @id @default(cuid())
  projectId         String
  title             String
  category          String
  quantity          Decimal         @db.Decimal(12, 2)
  unit              String
  status            ResourceStatus  @default(NEEDED)
  supplier          String?
  estimatedCost     Decimal?        @db.Decimal(12, 2)
  dueDate           DateTime?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key               String   @id
  value             String
  updatedAt         DateTime @updatedAt
}
